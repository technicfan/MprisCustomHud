{
    "schemaVersion": 1,
    "id": "mpriscustomhud",
    "version": "${version}",
    "name": "MprisCustomHud",
    "description": "(Linux only) Mpris song info addon for Customhud and Hudder",
    "authors": ["technicfan"],
    "contact": {
        "sources": "https://github.com/technicfan/MprisCustomHud"
    },
    "license": "MIT",
    "icon": "assets/mpriscustomhud/icon.png",
    "environment": "client",
    "entrypoints": {
        "main": ["technicfan.mpriscustomhud.MprisCustomHud"],
        "client": ["technicfan.mpriscustomhud.MprisCustomHudClient"]
    },
    "mixins": [],
    "depends": {
        "fabricloader": ">=${loader}",
        "minecraft": "${minecraft}",
        "java": ">=17",
        "fabric-api": "*"
    },
    "breaks": {
        "custom_hud": "${breaks_custom_hud}",
        "hudder": "${breaks_hudder}"
    }
}
